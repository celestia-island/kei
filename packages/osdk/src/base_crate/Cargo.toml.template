[workspace]

# An empty workspace table keeps the base crate away from nesting in other
# workspaces.
[package]
name = "#NAME#"
version = "#VERSION#"
edition = "2024"

[patch.crates-io]
ostd = { path = "/mnt/codespace/kei/packages/ostd" }
ostd-pod = { path = "/mnt/codespace/kei/packages/ostd/libs/ostd-pod" }
ostd-macros = { path = "/mnt/codespace/kei/packages/ostd/libs/ostd-macros" }
ostd-test = { path = "/mnt/codespace/kei/packages/ostd/libs/ostd-test" }
