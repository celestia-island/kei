#!/bin/sh

mount -t proc none /proc 2>/dev/null
mount -t sysfs none /sys 2>/dev/null

echo ""
echo "=== kei ignition (aarch64) ==="

# Start dropbear in foreground mode (-F), no fork on connection.
# The poll retry workaround handles select/poll readiness detection.
echo "Starting dropbear on port 22 (foreground)..."
/sbin/dropbear -F -E -R -p 22 &
sleep 2
echo "dropbear running"

echo ""
echo "Boot complete. SSH on port 22 (host port 2222)."
while true; do sleep 10; done










