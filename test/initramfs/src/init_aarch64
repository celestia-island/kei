#!/bin/sh

mount -t proc none /proc 2>/dev/null
mount -t sysfs none /sys 2>/dev/null

echo ""
echo "=== kei ignition (aarch64) ==="

mkdir -p /var/run

# Start dropbear in foreground mode (-F). This avoids musl daemon() fork
# which fails on aarch64. In -F mode, dropbear handles one connection then
# exits. The SSH client must connect while dropbear is running.
echo "Starting dropbear on port 22 (foreground)..."
/sbin/dropbear -F -E -R -p 22 &

echo ""
echo "Boot complete. SSH on port 22 (host port 2222)."
echo "Waiting for connections..."

# Keep the init process alive so the system doesn't shut down
while true; do sleep 10; done













