#!/bin/sh

mount -t proc none /proc 2>/dev/null
mount -t sysfs none /sys 2>/dev/null

echo ""
echo "=== kei ignition (aarch64) ==="

# Start dropbear in foreground, no fork on connection (-e), verbose (-E)
echo "Starting dropbear on port 22..."
/sbin/dropbear -F -E -e -R -p 22 &
sleep 2
echo "dropbear running"

echo ""
echo "Boot complete. SSH on port 22 (host port 2222)."
while true; do sleep 10; done








