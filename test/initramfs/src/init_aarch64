#!/bin/sh

mount -t proc none /proc 2>/dev/null
mount -t sysfs none /sys 2>/dev/null

echo ""
echo "=== kei ignition (aarch64) ==="

mkdir -p /var/run

# Start dropbear as daemon (no -F). The daemon forks a child for each
# connection. The poll retry workaround handles select/poll readiness.
echo "Starting dropbear on port 22..."
/sbin/dropbear -E -R -p 22
echo "dropbear started (pid=$?)"

echo ""
echo "Boot complete. SSH on port 22 (host port 2222)."
while true; do sleep 10; done












