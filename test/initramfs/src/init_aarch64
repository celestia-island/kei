#!/bin/sh

mount -t proc none /proc 2>/dev/null
mount -t sysfs none /sys 2>/dev/null

echo ""
echo "=== kei ignition (aarch64) ==="

echo "Bringing up networking..."
ifconfig lo 127.0.0.1 up 2>/dev/null
# Try to bring up the first ethernet interface (virtio-net = eth0)
ifconfig eth0 10.0.2.15 netmask 255.255.255.0 up 2>/dev/null && echo "  eth0 configured"
ifconfig 2>/dev/null | head -10

# Start dropbear SSH server (host keys are pre-generated in the initramfs)
echo "Starting dropbear on port 22..."
/sbin/dropbear -F -E -R -p 22 2>&1 &
sleep 2
echo "dropbear launched"

echo ""
echo "Boot complete. SSH on port 22."
exec /bin/sh




