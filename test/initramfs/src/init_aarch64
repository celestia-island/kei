#!/bin/sh

mount -t proc none /proc 2>/dev/null
mount -t sysfs none /sys 2>/dev/null

echo ""
echo "=== kei ignition (aarch64) ==="

# Start dropbear in foreground with verbose logging.
# -F: foreground, -E: log to stderr, -R: auto-gen host keys if missing
echo "Starting dropbear on port 22 (foreground, verbose)..."
/sbin/dropbear -F -E -R -p 22 2>&1 &
sleep 2
echo "dropbear running in background"

echo ""
echo "Boot complete. SSH on port 22 (host port 2222)."
# Keep alive
while true; do sleep 10; done






